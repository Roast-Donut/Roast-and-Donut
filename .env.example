# ── Neon Postgres ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/neondb?sslmode=require

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
